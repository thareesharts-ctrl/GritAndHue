datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String     @id @default(uuid())
  name        String
  description String?
  price       Float
  category    String     // 'kids' or 'men'
  images      String[]   // Native PostgreSQL array support
  sizes       String[]   // Native PostgreSQL array support
  tag         String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  cartItems   CartItem[]

  @@map("products")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      String     @default("user")
  favorites String[]   // Native PostgreSQL array support for favorites product IDs
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  
  cart      CartItem[]
  addresses Address[]

  @@map("users")
}

model CartItem {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  productId    String  @map("product_id")
  quantity     Int     @default(1)
  selectedSize String  @map("selected_size")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, selectedSize])
  @@map("cart_items")
}

model Order {
  id        String   @id @default(uuid())
  orderCode String   @unique @map("order_code")
  items     Json     // Cart items snapshot
  total     Float
  createdAt DateTime @default(now()) @map("created_at")

  @@map("orders")
}

model Address {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String   // E.g. "Home", "Work", "John's Place"
  phone        String
  email        String?
  street       String
  apartment    String?
  city         String
  state        String
  zipCode      String   @map("zip_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}
